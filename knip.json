{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": ["src/index.ts", "src/main.ts", "src/voice/from-env.ts", "src/voice/mcp/server.ts"],
  "project": ["src/**/*.{ts,js}"],
  "ignoreUnresolved": ["bun-types"],
  "rules": {
    "exports": "warn",
    "types": "warn",
    "nsExports": "warn",
    "nsTypes": "warn",
    "enumMembers": "warn"
  }
}
